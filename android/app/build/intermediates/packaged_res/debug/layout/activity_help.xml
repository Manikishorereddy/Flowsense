<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#060714">

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp">
            
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_right"
                android:rotation="180"
                app:tint="#FFFFFF"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Help and Support"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                app:layout_constraintStart_toEndOf="@+id/btnBack"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Points List -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_list_item"
            android:padding="20dp"
            android:layout_marginBottom="32dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1." android:textColor="#1CB5E0" android:textSize="16sp" android:textStyle="bold" android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Getting Started: Use the dashboard to monitor queue wait times and real-time CCTV analysis." android:textColor="#FFFFFF" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2." android:textColor="#1CB5E0" android:textSize="16sp" android:textStyle="bold" android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Account Issues: If you are unable to login, you can reset your password or contact our support team." android:textColor="#FFFFFF" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3." android:textColor="#1CB5E0" android:textSize="16sp" android:textStyle="bold" android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Predictions: FlowSense uses AI to predict crowd density. Wait times may fluctuate based on real-world events." android:textColor="#FFFFFF" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4." android:textColor="#1CB5E0" android:textSize="16sp" android:textStyle="bold" android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Data Sync: Your preferences and profiles are synced instantly across your devices via the cloud." android:textColor="#FFFFFF" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5." android:textColor="#1CB5E0" android:textSize="16sp" android:textStyle="bold" android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Need more help? Our 24/7 technical team is available to assist you via email below." android:textColor="#FFFFFF" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
            </LinearLayout>
            
        </LinearLayout>

        <!-- Email Support Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnEmailHelp"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Email Support"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_gradient" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
