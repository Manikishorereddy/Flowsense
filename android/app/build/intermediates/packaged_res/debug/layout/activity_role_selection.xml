<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_bg"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Choose your role"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSubHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select your account type to proceed to login"
        android:textColor="#8C92A6"
        android:textSize="16sp"
        android:textAlignment="center"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@+id/tvHeader" />

    <!-- Organization Card -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardOrg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_role_card"
        android:padding="24dp"
        android:layout_marginTop="48dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@+id/tvSubHeader">

        <ImageView
            android:id="@+id/ivOrgIcon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_icon_org"
            android:src="@drawable/ic_building"
            android:padding="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvOrgTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Organization"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            app:layout_constraintTop_toTopOf="@+id/ivOrgIcon"
            app:layout_constraintStart_toEndOf="@+id/ivOrgIcon"
            app:layout_constraintEnd_toStartOf="@+id/ivOrgArrow" />

        <TextView
            android:id="@+id/tvOrgDesc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Manage crowd data &amp; updates"
            android:textColor="#8C92A6"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@+id/tvOrgTitle"
            app:layout_constraintStart_toStartOf="@+id/tvOrgTitle"
            app:layout_constraintEnd_toStartOf="@+id/ivOrgArrow" />

        <TextView
            android:id="@+id/ivOrgArrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textColor="#8C92A6"
            android:textSize="32sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- User Card -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_role_card"
        android:padding="24dp"
        android:layout_marginTop="20dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@+id/cardOrg">

        <ImageView
            android:id="@+id/ivUserIcon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_icon_user"
            android:src="@drawable/ic_user"
            android:padding="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvUserTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="User"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            app:layout_constraintTop_toTopOf="@+id/ivUserIcon"
            app:layout_constraintStart_toEndOf="@+id/ivUserIcon"
            app:layout_constraintEnd_toStartOf="@+id/ivUserArrow" />

        <TextView
            android:id="@+id/tvUserDesc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Check wait times &amp; plan visits"
            android:textColor="#8C92A6"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@+id/tvUserTitle"
            app:layout_constraintStart_toStartOf="@+id/tvUserTitle"
            app:layout_constraintEnd_toStartOf="@+id/ivUserArrow" />

        <TextView
            android:id="@+id/ivUserArrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textColor="#8C92A6"
            android:textSize="32sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
