<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_list_item"
    android:padding="12dp"
    android:layout_marginBottom="12dp"
    android:gravity="center_vertical">

    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="#141829"
        android:layout_marginEnd="12dp">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_cctv"
            app:tint="#1CB5E0" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tvVideoTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Main Entrance"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvVideoDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Uploaded just now"
            android:textColor="#8C92A6"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/btnPlayVideo"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="8dp"
        android:src="@drawable/ic_pulse_logo"
        app:tint="#27AE60"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_marginEnd="8dp" />

    <ImageView
        android:id="@+id/btnDeleteVideo"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="8dp"
        android:src="@drawable/ic_delete"
        app:tint="#FF4D4D"
        android:background="?attr/selectableItemBackgroundBorderless" />

</LinearLayout>
