<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#060714">

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp">
            
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_right"
                android:rotation="180"
                app:tint="#FFFFFF"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Privacy and Policy"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                app:layout_constraintStart_toEndOf="@+id/btnBack"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Points List -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_list_item"
            android:padding="20dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1." android:textColor="#1CB5E0" android:textSize="16sp" android:textStyle="bold" android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Data Collection: We collect only the data necessary to provide and improve FlowSense AI services." android:textColor="#FFFFFF" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2." android:textColor="#1CB5E0" android:textSize="16sp" android:textStyle="bold" android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Data Security: Your video feeds and personal information are encrypted in transit and at rest." android:textColor="#FFFFFF" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3." android:textColor="#1CB5E0" android:textSize="16sp" android:textStyle="bold" android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="No Third-Party Selling: We strictly do not sell your personal data or video analytics to third parties." android:textColor="#FFFFFF" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4." android:textColor="#1CB5E0" android:textSize="16sp" android:textStyle="bold" android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="User Control: You retain the right to delete your account and all associated data at any time." android:textColor="#FFFFFF" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5." android:textColor="#1CB5E0" android:textSize="16sp" android:textStyle="bold" android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI Processing: Video feeds are processed strictly for wait-time estimation and are not stored permanently." android:textColor="#FFFFFF" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
            </LinearLayout>
            
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
